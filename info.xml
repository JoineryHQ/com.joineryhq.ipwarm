<?xml version="1.0"?>
<extension key="com.joineryhq.ipwarm" type="module">
  <file>ipwarm</file>
  <name>IP Warming</name>
  <description>Limits, and gradually increases, outbound email volume for warming a new dedicated IP address.</description>
  <license>GPL-3.0</license>
  <maintainer>
    <author>Allen Shaw</author>
    <email>allen@joineryhq.com</email>
  </maintainer>
  <urls>
    <url desc="Main Extension Page">https://github.com/JoineryHQ/com.joineryhq.ipwarm</url>
    <url desc="Documentation">https://github.com/JoineryHQ/com.joineryhq.ipwarm</url>
    <url desc="Support">https://github.com/JoineryHQ/com.joineryhq.ipwarm/issues</url>
    <url desc="Licensing">http://www.gnu.org/licenses/gpl-3.0.html</url>
  </urls>
  <releaseDate>2021-03-24</releaseDate>
  <version>1.0.1</version>
  <develStage>beta</develStage>
  <compatibility>
    <ver>5.51</ver>
  </compatibility>
  <comments>Developed by Joinery</comments>
  <classloader>
    <psr4 prefix="Civi\" path="Civi"/>
    <psr0 prefix="CRM_" path="."/>
  </classloader>
  <civix>
    <namespace>CRM/Ipwarm</namespace>
    <format>25.10.2</format>
  </civix>
  <mixins>
    <mixin>menu-xml@1.0.0</mixin>
    <mixin>setting-php@1.0.0</mixin>
    <mixin>smarty-v2@1.0.3</mixin>
    <mixin>scan-classes@1.0.0</mixin>
  </mixins>
  <upgrader>CiviMix\Schema\Ipwarm\AutomaticUpgrader</upgrader>
</extension>
